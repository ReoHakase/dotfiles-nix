{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":dependencyDashboard",
    // Immutable action refs + tag comment — see helpers:pinGitHubActionDigests preset.
    // https://docs.renovatebot.com/modules/manager/github-actions/
    "helpers:pinGitHubActionDigests",
  ],
  timezone: "Asia/Tokyo",
  schedule: ["before 6am every weekday"],
  labels: ["dependencies"],
  prConcurrentLimit: 4,
  prHourlyLimit: 4,

  // flake.lock は nix manager が rev / narHash を更新。個別 *.nix の fetchurl hash 等は
  // packageRules の postUpgradeTasks（curl + nix hash / nix-update）で追随させる。
  nix: { enabled: true },
  lockFileMaintenance: {
    enabled: true,
    schedule: ["before 6am on monday"],
  },

  customManagers: [
    {
      description: "Vicinae AppImage (fixed-output fetchurl)",
      customType: "regex",
      managerFilePatterns: ["^pkgs/appimages/vicinae\\.nix$"],
      matchStrings: ['version\\s*=\\s*"(?<currentValue>[^"]+)";'],
      datasourceTemplate: "github-releases",
      depNameTemplate: "vicinaehq/vicinae",
      extractVersionTemplate: "^v(?<version>.+)$",
      versioningTemplate: "semver",
    },
  ],

  packageRules: [
    {
      description: "Pin actions/setup-node node-version inputs (uses-with deps).",
      matchManagers: ["github-actions"],
      matchDepTypes: ["uses-with"],
      matchDepNames: ["node"],
      rangeStrategy: "pin",
    },
    {
      matchManagers: ["nix"],
      groupName: "flake inputs",
      semanticCommitType: "chore",
      semanticCommitScope: "flake",
    },
    {
      description: "Recompute Vicinae fetchurl SRI hash after semver bump.",
      matchManagers: ["regex"],
      matchDatasources: ["github-releases"],
      matchPackageNames: ["vicinaehq/vicinae"],
      semanticCommitType: "chore",
      semanticCommitScope: "vicinae",
      postUpgradeTasks: {
        commands: ["bash scripts/renovate/bump-vicinae-appimage.sh {{{newVersion}}}"],
        fileFilters: ["pkgs/appimages/vicinae.nix"],
        executionMode: "update",
      },
    },
  ],

  allowedPostUpgradeCommands: [
    "^bash scripts/renovate/bump-vicinae-appimage\\.sh [-\\.0-9A-Za-z+]+$",
  ],
}
