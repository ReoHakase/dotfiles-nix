{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":dependencyDashboard",
    // Immutable action refs + tag comment — see helpers:pinGitHubActionDigests preset.
    // https://docs.renovatebot.com/modules/manager/github-actions/
    "helpers:pinGitHubActionDigests",
  ],
  timezone: "Asia/Tokyo",
  schedule: ["before 6am every weekday"],
  labels: ["dependencies"],
  // claude-code は毎日のように patch が出るので同時 PR を抑える。
  prConcurrentLimit: 4,
  prHourlyLimit: 4,

  // nix マネージャで flake.lock を週次 bump する。
  nix: { enabled: true },
  lockFileMaintenance: {
    enabled: true,
    schedule: ["before 6am on monday"],
  },

  customManagers: [
    {
      description: "@anthropic-ai/claude-code semver in pkgs/npm/claude-code/package.nix",
      // pkgs/npm/claude-code/package.nix の `version = "X.Y.Z";` を npm registry と突き合わせる。
      customType: "regex",
      managerFilePatterns: ["^pkgs/npm/claude-code/package\\.nix$"],
      matchStrings: ['version\\s*=\\s*"(?<currentValue>[^"]+)";'],
      datasourceTemplate: "npm",
      depNameTemplate: "@anthropic-ai/claude-code",
      versioningTemplate: "semver",
    },
    {
      description: "openai/codex release tag rust-vX.Y.Z in pkgs/npm/codex/package.nix",
      // pkgs/npm/codex/package.nix の `version = "X.Y.Z";` を GitHub Releases (tag: rust-vX.Y.Z) と突き合わせる。
      customType: "regex",
      managerFilePatterns: ["^pkgs/npm/codex/package\\.nix$"],
      matchStrings: ['version\\s*=\\s*"(?<currentValue>[^"]+)";'],
      datasourceTemplate: "github-releases",
      depNameTemplate: "openai/codex",
      extractVersionTemplate: "^rust-v(?<version>.+)$",
      versioningTemplate: "semver",
    },
  ],

  packageRules: [
    {
      description: "Pin actions/setup-node node-version inputs (uses-with deps).",
      matchManagers: ["github-actions"],
      matchDepTypes: ["uses-with"],
      matchDepNames: ["node"],
      rangeStrategy: "pin",
    },
    {
      matchManagers: ["nix"],
      groupName: "flake inputs",
      semanticCommitType: "chore",
      semanticCommitScope: "flake",
    },
    {
      matchPackageNames: ["@anthropic-ai/claude-code"],
      semanticCommitType: "chore",
      semanticCommitScope: "claude-code",
      // claude-code 更新時のみ update-claude-code.sh を走らせて
      // package-lock.json 再生成 + src.hash / npmDepsHash 更新をする。
      postUpgradeTasks: {
        commands: ["bash scripts/renovate/update-claude-code.sh {{{newVersion}}}"],
        fileFilters: ["pkgs/npm/claude-code/**"],
        executionMode: "update",
      },
    },
    {
      matchPackageNames: ["openai/codex"],
      semanticCommitType: "chore",
      semanticCommitScope: "codex",
      // codex 更新時は prebuilt tarball の SRI hash を各 triple 分書き換える。
      postUpgradeTasks: {
        commands: ["bash scripts/renovate/update-codex.sh {{{newVersion}}}"],
        fileFilters: ["pkgs/npm/codex/**"],
        executionMode: "update",
      },
    },
  ],

  // セルフホスト側で実行を許可するコマンドの allowlist (正規表現、完全一致)。
  // Renovate config 上では repo config に書くことで、self-hosted の global config からも merge される。
  allowedPostUpgradeCommands: [
    "^bash scripts/renovate/update-claude-code\\.sh [0-9]+\\.[0-9]+\\.[0-9]+$",
    "^bash scripts/renovate/update-codex\\.sh [0-9]+\\.[0-9]+\\.[0-9]+$",
  ],
}
